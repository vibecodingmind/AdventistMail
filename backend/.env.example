# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/adventist_church_mail

# Redis
REDIS_URL=redis://localhost:6379

# Zimbra / LDAP
ZIMBRA_LDAP_URL=ldaps://mail.church.org:636
ZIMBRA_LDAP_BASE_DN=dc=church,dc=org
ZIMBRA_LDAP_BIND_DN=uid=zimbra,cn=admins,cn=zimbra
ZIMBRA_LDAP_BIND_PASSWORD=

# IMAP
ZIMBRA_IMAP_HOST=mail.church.org
ZIMBRA_IMAP_PORT=993
ZIMBRA_IMAP_SECURE=true

# SMTP
ZIMBRA_SMTP_HOST=mail.church.org
ZIMBRA_SMTP_PORT=587
ZIMBRA_SMTP_SECURE=false

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
